{
  "name": "latticechat",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    "web",
    "server"
  ],
  "scripts": {
    "generate:diagrams": "bash scripts/generate-diagrams.sh" ,

    "fetch-commits": "git log --reverse --pretty=format:\"%H %an %ad %s\" --date=iso > commit_history.txt",
    "dev": "concurrently \"yarn workspace server dev\" \"yarn workspace web dev\"",
    "build": "yarn workspaces foreach --all -pt run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
