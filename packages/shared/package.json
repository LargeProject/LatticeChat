{
  "name": "@latticechat/shared",
  "version": "1.0.0",
  "description": "Shared types, contracts, and utilities for LatticeChat",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./contracts/websocket": {
      "types": "./dist/contracts/websocket/client.d.ts",
      "import": "./dist/contracts/websocket/client.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'tsx' src/index.ts"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  }
}
